    App --> MenuBase
    App --> AboutMenu
    App --> UserSvc

    App -->|Admin| UserMonitor
    App -->|Admin| BookMonitor
    App -->|Admin| CopyMonitor
    App -->|Admin| LoanMonitor
    App -->|Patron| SearchMenu
    App -->|Patron| LoanMenu
    App -->|Patron| PersonalMenu

    UserMonitor --> UserSvc
    BookMonitor --> BookSvc
    BookMonitor --> CopySvc
    CopyMonitor --> CopySvc
    CopyMonitor --> BookSvc
    LoanMonitor --> LoanSvc
    LoanMonitor --> UserSvc
    SearchMenu --> BookSvc
    SearchMenu --> CopySvc
    LoanMenu --> LoanSvc
    LoanMenu --> UserSvc
    LoanMenu --> BookSvc
    LoanMenu --> CopySvc
    PersonalMenu --> UserSvc
    PersonalMenu --> LoanSvc

    BookSvc --> BookDao
    CopySvc --> CopyDao
    LoanSvc --> LoanDao
    UserSvc --> UserDao

    LoanSvc --> UserSvc
    LoanSvc --> BookSvc
    LoanSvc --> CopySvc
    LoanSvc --> TimeSvc

    BookDao --> F1
    CopyDao --> F2
    UserDao --> F3
    LoanDao --> F4

