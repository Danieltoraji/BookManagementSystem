    style DAO fill:#fffaf0,stroke:#dd6b20
    style Model fill:#faf5ff,stroke:#805ad5
    style DataFiles fill:#fff5f5,stroke:#e53e3e
    style AdminSub fill:#dbeafe,stroke:#3182ce
    style UserSub fill:#dbeafe,stroke:#3182ce
