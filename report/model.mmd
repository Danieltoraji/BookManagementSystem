%%{ init: { 'theme': 'base', 'themeVariables': { 'primaryColor': '#4a90d9', 'primaryTextColor': '#fff', 'primaryBorderColor': '#2c5f9e', 'lineColor': '#555', 'fontSize': '14px' } } }%%

flowchart TB
    %% ============ 入口 ============
    subgraph Entry["🚀 程序入口"]
        Main["main.cpp<br/>设置 UTF-8 编码<br/>创建 App 并启动"]
    end

    %% ============ 控制台层 ============
    subgraph Console["🖥️ 控制台层 (console/) — 用户界面与交互"]
        direction TB
        App["App<br/>应用主控制器<br/>──────────<br/>• 登录流程 loginFlow<br/>• 注册 doRegister<br/>• 角色菜单分发<br/>• 显示关于信息"]

        MenuBase["MenuBase<br/>菜单工具基类<br/>──────────<br/>• displayMenu 显示菜单<br/>• readLine / readInt 输入<br/>• pause / clearScreen<br/>• printSeparator 分隔线"]

        AboutMenu["AboutMenu<br/>关于菜单<br/>──────────<br/>• 显示系统信息"]

        AdminMenu["AdminMenu<br/>管理员主菜单<br/>──────────<br/>• 调度各监控子菜单"]

        UserMenu["UserMenu<br/>用户主菜单<br/>──────────<br/>• 调度各用户子菜单"]

        subgraph AdminSub["管理员子菜单 (admin_submenu/)"]
            UserMonitor["UserMonitorMenu<br/>用户监控<br/>──────────<br/>• 查看/搜索用户<br/>• 添加 Patron/Admin<br/>• 修改信息/密码<br/>• 删除用户<br/>• 文件读写"]
            BookMonitor["BookMonitorMenu<br/>图书监控<br/>──────────<br/>• 搜索/显示图书<br/>• 添加/修改/删除<br/>• 文件读写"]
            BookCopyMonitor["BookCopyMonitorMenu<br/>副本监控<br/>──────────<br/>• 查看/搜索副本<br/>• 添加/修改/注销/删除<br/>• 文件读写"]
            LoanMonitor["LoanMonitorMenu<br/>借阅监控<br/>──────────<br/>• 查看/搜索借阅记录<br/>• 当前借阅统计<br/>• 最受欢迎图书<br/>• 最活跃用户<br/>• 月度统计<br/>• 文件读写"]
        end

        subgraph UserSub["用户子菜单 (user_submenu/)"]
            SearchInfo["SearchInfoMenu<br/>信息查询<br/>──────────<br/>• 浏览图书/副本<br/>• 多条件搜索<br/>• 查看书架位置"]
            LoanMenu["LoanMenu<br/>借阅操作<br/>──────────<br/>• 借书 / 还书 / 续借<br/>• 当前借阅查看<br/>• 借阅历史<br/>• 图书推荐"]
            PersonalInfo["PersonalInfoMenu<br/>个人信息<br/>──────────<br/>• 查看个人信息<br/>• 修改信息<br/>• 修改密码<br/>• 注销账号"]
        end
    end

    %% ============ 服务层 ============
    subgraph Services["⚙️ 服务层 (services/) — 业务逻辑"]
        direction TB
        BookService["BookService (单例)<br/>图书服务<br/>──────────<br/>• 图书 CRUD<br/>• 多条件搜索 searchQuery<br/>• ISBN 查询/验证<br/>• 文件读写<br/>• 数据主存: books[]"]

        BookCopyService["bookCopyService (单例)<br/>副本服务<br/>──────────<br/>• 副本 CRUD<br/>• 按 ISBN/馆码/位置查询<br/>• 馆码可用性检查<br/>• 按 ISBN 批量注销<br/>• 数据主存: bookCopies[]"]

        LoanService["loanService (单例)<br/>借阅服务<br/>──────────<br/>• 借书 / 还书 / 续借<br/>• 级联归还(按馆码/ISBN)<br/>• 借阅记录查询<br/>• 统计: 总量/热门/活跃/月度<br/>• 数据主存: loans[]"]

        UserService["UserService (单例)<br/>用户服务<br/>──────────<br/>• 用户 CRUD (Patron/Admin)<br/>• 身份认证 authenticate<br/>• 密码异或加密/解密<br/>• 当前用户管理<br/>• 数据主存: users[]"]

        TimeService["TimeService (单例)<br/>时间服务<br/>──────────<br/>• 计算应还日期 (+30天)<br/>• 计算续期日期 (+15天)<br/>• 借阅规则常量"]
    end

    %% ============ DAO 层 ============
    subgraph DAO["💾 数据访问层 (dao/) — 文件序列化"]
        direction TB
        BookDao["BookDao (单例)<br/>──────────<br/>• loadBooksFromFile<br/>• saveBooksToFile<br/>• Book ↔ 文本行序列化"]

        BookCopyDao["BookCopyDao (单例)<br/>──────────<br/>• loadBookCopiesFromFile<br/>• saveBookCopiesToFile<br/>• BookCopy ↔ 文本行序列化"]

        LoanDao["LoanDao (单例)<br/>──────────<br/>• loadLoansFromFile<br/>• saveLoansToFile<br/>• Loan ↔ 文本行序列化"]

        UserDao["UserDao (单例)<br/>──────────<br/>• loadUsersFromFile<br/>• saveUsersToFile<br/>• User(多态) ↔ 文本行序列化"]
    end

    %% ============ 模型层 ============
    subgraph Model["📦 模型层 (model/) — 数据实体"]
        direction TB
        Book["Book<br/>图书<br/>──────────<br/>ISBN / 标题 / 作者<br/>出版社 / 年份<br/>分类 / 备注"]

        BookCopy["BookCopy<br/>图书副本<br/>──────────<br/>ISBN / 馆码<br/>Location 位置<br/>status: available/<br/>borrowed/cancelled"]

        Loan["Loan<br/>借阅记录<br/>──────────<br/>id / 馆码 / ISBN<br/>userId / 借阅日期<br/>应还日期 / 归还日期<br/>isReturned / 逾期判断"]

        User["User (抽象基类)<br/>用户<br/>──────────<br/>id / username<br/>phone / email<br/>password (加密)"]

        Admin["Admin : User<br/>管理员<br/>──────────<br/>displayInfo()"]

        Patron["Patron : User<br/>读者<br/>──────────<br/>borrowLimit 借阅上限"]

        Date["Date<br/>日期<br/>──────────<br/>年/月/日<br/>儒略日换算<br/>日期加减/比较<br/>today() / 序列化"]

        Location["Location<br/>馆藏位置<br/>──────────<br/>馆 / 层 / 排<br/>列 / 层<br/>toString() 序列化"]
    end

    %% ============ 数据文件 ============
    subgraph DataFiles["📄 数据文件 (data/)"]
        BooksFile["books.txt<br/>ISBN|Title|Author|<br/>Publisher|Year|Category|Remarks"]
        BookCopiesFile["bookcopies.txt<br/>ISBN|libCode|Location|status"]
        LoansFile["loans.txt<br/>id|libCode|ISBN|userId|<br/>loanDate|dueDate|returnDate|isReturned"]
        UsersFile["users.txt<br/>Type|id|username|phone|<br/>email|password(加密)"]
    end

    %% ============ 层间调用关系 ============
    Main --> App
    App --> MenuBase
    App -->|管理员登录| AdminMenu
    App -->|用户登录| UserMenu
    App --> AboutMenu
    AdminMenu --> UserMonitor
    AdminMenu --> BookMonitor
    AdminMenu --> BookCopyMonitor
    AdminMenu --> LoanMonitor
    UserMenu --> SearchInfo
    UserMenu --> LoanMenu
    UserMenu --> PersonalInfo

    %% 控制台 → 服务层
    UserMonitor --> UserService
    BookMonitor --> BookService
    BookMonitor --> BookCopyService
    BookCopyMonitor --> BookCopyService
    BookCopyMonitor --> BookService
    LoanMonitor --> LoanService
    LoanMonitor --> UserService
    LoanMonitor --> BookService
    LoanMonitor --> BookCopyService
    SearchInfo --> BookService
    SearchInfo --> BookCopyService
    LoanMenu --> LoanService
    LoanMenu --> BookService
    LoanMenu --> BookCopyService
    LoanMenu --> UserService
    PersonalInfo --> UserService
    PersonalInfo --> LoanService
    App --> UserService

    %% 服务层内部依赖
    LoanService --> BookService
    LoanService --> BookCopyService
    LoanService --> UserService
    LoanService --> TimeService

    %% 服务层 → DAO 层
    BookService --> BookDao
    BookCopyService --> BookCopyDao
    LoanService --> LoanDao
    UserService --> UserDao

    %% DAO 层 → 数据文件
    BookDao --> BooksFile
    BookCopyDao --> BookCopiesFile
    LoanDao --> LoansFile
    UserDao --> UsersFile

    %% 服务层 → 模型层 (持有数据)
    BookService -.->|持有| Book
    BookCopyService -.->|持有| BookCopy
    LoanService -.->|持有| Loan
    UserService -.->|持有| User

    %% 模型层内部组合
    BookCopy --> Location
    Loan --> Date
    Admin -.->|继承| User
    Patron -.->|继承| User

